#include <stdio.h>
#include "system.h"
#include "altera_avalon_pio_regs.h"

int main()
{
    // Startup message
    printf("Hello from Nios V/M!\n");

    // Turn ON all LEDs (10-bit PIO)
    IOWR_ALTERA_AVALON_PIO_DATA(LED_10OUTPUTS_BASE, 0x3FF);

    // Read and display LED value
    int led_value = IORD_ALTERA_AVALON_PIO_DATA(LED_10OUTPUTS_BASE);
    printf("LEDs value: 0x%x\n", led_value);

    // Infinite loop
    while(1)
    {
    }

    return 0;
}
